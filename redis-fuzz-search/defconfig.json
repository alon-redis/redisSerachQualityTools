{
  "blacklist": [
	"AUTH","BGREWRITEAOF","BGSAVE","DEBUG","DISCARD",
	"EVAL","EVAL_RO","EVALSHA","EVALSHA_RO","EXEC","FAILOVER",
	"FCALL","FCALL_RO","HELLO","MONITOR","MULTI","PSUBSCRIBE",
	"PUNSUBSCRIBE","QUIT","REPLCONF","RESET",
	"ROLE","SAVE","SHUTDOWN","SLAVEOF","SSUBSCRIBE","SUBSCRIBE",
	"SUNSUBSCRIBE","SYNC","UNSUBSCRIBE","UNWATCH","WATCH",
	"COMMAND","FLUSHALL","FLUSHDB","PFSELFTEST","SFLUSH",
	"PSYNC","REPLICAOF",
	"FT.CONFIG","FT._LIST","FT._ALIASADDIFNX","FT._ALIASDELIFX",
	"FT._ALTERIFNX","FT._CREATEIFNX","FT._DROPINDEXIFX",
	"FT._DROPIFX"
  ],
  "whitelist": [],
  "modules": ["core", "search"],

  "max_seq_len": 2048,
  "insert_max_len": 16,

  "weights": {
    "group": {
      "search": 8.0,
      "generic": 0.3,
      "server": 0.1,
      "connection": 0.1,
      "scripting": 0.0,
      "pubsub": 0.0,
      "transactions": 0.0,
      "cluster": 0.0,
      "geo": 0.2,
      "stream": 0.2,
      "list": 0.2,
      "set": 0.3,
      "sorted_set": 0.2,
      "hash": 1.5,
      "string": 0.5,
      "hyperloglog": 0.1,
      "bitmap": 0.1
    },
    "command": {
      "FT.SEARCH": 4.0,
      "FT.AGGREGATE": 3.0,
      "FT.EXPLAIN": 2.0,
      "FT.EXPLAINCLI": 1.0,
      "FT.PROFILE": 2.0,
      "FT.CREATE": 1.5,
      "FT.ALTER": 1.0,
      "FT.DROPINDEX": 0.5,
      "FT.INFO": 0.5,
      "FT.TAGVALS": 0.5,
      "FT.SUGADD": 1.0,
      "FT.SUGGET": 1.0,
      "FT.DICTADD": 0.5,
      "FT.SPELLCHECK": 1.0,
      "FT.SYNUPDATE": 0.5,
      "FT.CURSOR": 1.0
    }
  },

  "preconditions": { "enable": true, "probability": 0.25 },

  "blocking": { "allow": false },

  "mutation": {
    "probabilities": {
      "delete_chunk": 0.10,
      "duplicate_chunk": 0.10,
      "insert_generated": 0.22,
      "replace_generated": 0.22,
      "swap_commands": 0.10,
      "shuffle_window": 0.08,
      "arg_mutate": 0.22
    },
    "splice": { "enable": true, "probability": 0.07, "max_len": 64 },
    "string": { "max_len": 128, "special_prob": 0.30 }
  }
}
